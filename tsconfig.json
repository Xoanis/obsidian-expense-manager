{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "obsidian": [
        "node_modules/obsidian"
      ],
      "obsidian-para-suite-contracts": [
        "node_modules/obsidian-para-suite-contracts/src/index.ts"
      ],
      "obsidian-para-suite-contracts/*": [
        "node_modules/obsidian-para-suite-contracts/src/*"
      ]
    },
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES6",
    "allowJs": true,
    "noImplicitAny": true,
    "moduleResolution": "node",
    "importHelpers": true,
    "isolatedModules": true,
    "strictNullChecks": true,
    "lib": [
      "DOM",
      "ES5",
      "ES6",
      "ES7"
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.d.ts"
  ]
}
